APP_NAME=Regenesis
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/London

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev uses SQLite. Production (Hostinger) flips to mysql + the
# domain DB credentials provisioned in hPanel.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# ─── Regenesis guild ────────────────────────────────────────────────
# Matches the guild key that GRM writes into its SavedVariables tables
# (GRM_GuildMemberHistory_Save["Regenesis-Silvermoon"], etc.).
GUILD_KEY=Regenesis-Silvermoon

# ─── GRM ingest ─────────────────────────────────────────────────────
# Bearer token the PowerShell sync tool sends in Authorization header.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
GRM_INGEST_TOKEN=

# ─── Discord OAuth + role gate ──────────────────────────────────────
# Created in https://discord.com/developers/applications
# Redirect URI: {APP_URL}/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI="${APP_URL}/auth/discord/callback"
# Regenesis Discord server (already known).
DISCORD_GUILD_ID=1247256415542841416
# Sign-in is gated on holding ANY of these roles. v1 treats them all the
# same; v2 may diverge per-feature via Laravel Gates.
DISCORD_ROLE_GM=1247279261434384415
DISCORD_ROLE_BIG6=1490762074584780951
DISCORD_ROLE_OFFICER=1247278529163296789

# ─── Raid-Helper ────────────────────────────────────────────────────
# Server API key from /apikey in Discord (NOT /usersettings apikey).
# Webhook key from /webhooks show. Subscribe via three commands (one per
# event type), then /webhooks refresh-key if the key ever leaks:
#   /webhooks set type:event.create url:{APP_URL}/api/webhook/raidhelper
#   /webhooks set type:event.update url:{APP_URL}/api/webhook/raidhelper
#   /webhooks set type:event.delete url:{APP_URL}/api/webhook/raidhelper
RAID_HELPER_API_KEY=
RAID_HELPER_WEBHOOK_KEY=
RAID_HELPER_SERVER_ID="${DISCORD_GUILD_ID}"
# Default channel events get posted to. Right-click channel > Copy ID.
RAID_HELPER_DEFAULT_CHANNEL_ID=
# Timezone events render in. Defaults to Europe/Paris (WoW EU realm
# time). Decoupled from APP_TIMEZONE so changing it doesn't affect
# Laravel's internal timestamps.
RAIDHELPER_TIMEZONE=Europe/Paris
# Default time of day (24h HH:MM) the create form pre-fills tomorrow's
# date with. Officers can edit before submitting.
RAIDHELPER_DEFAULT_TIME=19:30
# ─── wowaudit ───────────────────────────────────────────────────────
# Team API key from https://wowaudit.com -> Settings -> API.
# Sent as `Authorization: Bearer <key>`. Rotate via the same screen if
# it ever leaks. Empty key disables every wowaudit:* command cleanly.
WOWAUDIT_API_KEY=

# ─── Warcraft Logs (v2 API) ─────────────────────────────────────────
# Register a v2 client at https://www.warcraftlogs.com/api/clients/
# (one per guild is plenty). We use the client-credentials grant, so
# the redirect URI is never actually hit - the form just requires a
# syntactically valid HTTPS URL. Suggested value:
#   https://regenesis.enhanceify.co.uk/wcl/callback
# Both blank disables the WCL pull cleanly (sync button + artisan
# command print "not configured" instead of erroring).
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=
# Guild identity used in the reports query. Server slug is lower-case
# with hyphens (twisting-nether, not "Twisting Nether").
WCL_GUILD_NAME=Regenesis
WCL_GUILD_SERVER_SLUG=silvermoon
WCL_GUILD_SERVER_REGION=EU
# How many of the latest reports to fetch on each sync. 25 covers a
# couple of weeks of raid nights without overlapping pages.
WCL_REPORTS_PER_PULL=25

# ─── Blizzard / Battle.net (WoW Profile API) ────────────────────────
# Register a client at https://develop.battle.net/access/clients (one
# per environment is fine). We use the client_credentials grant; the
# redirect URI is never actually hit, just enter a valid HTTPS URL on
# the form. Both blank disables every blizzard:* command cleanly.
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
# Region. Two-letter code: us, eu, kr, tw, cn. Drives the default API
# host (eu.api.blizzard.com) and Battlenet-Namespace (profile-eu).
BLIZZARD_REGION=eu
# Locale for localised strings in API responses. Doesn't affect ilvl.
BLIZZARD_LOCALE=en_GB

# ─── SimulationCraft profiles (BiS reference data) ──────────────────
# Local filesystem path to a tier folder full of .simc profile files
# (e.g. profiles/MID1 inside a clone of github.com/simulationcraft/simc).
# The simc:pull command parses each file and upserts BiS gear / enchant /
# gem / consumable data per class+spec+hero-talent. Empty disables the
# command cleanly so a deploy without the path set doesn't error.
SIMC_PROFILES_PATH=
# Cosmetic label shown in command output. Bump when a new tier lands.
SIMC_TIER_LABEL=MID1
