# Snapshot raw payloads from the GRM ingest endpoint. Gzipped JSON kept
# for 90 days for replay; never belongs in git.
/storage/app/snapshots/*
!/storage/app/snapshots/.gitkeep

# NOTE: /public/build is intentionally NOT ignored. Hostinger has no node,
# so Vite output is committed and ships via git pull. See deploy.ps1.
