# Snapshot raw payloads from the GRM ingest endpoint. Gzipped JSON kept
# for 90 days for replay; never belongs in git.
/storage/app/snapshots/*
!/storage/app/snapshots/.gitkeep

# Local smoke-test render artifact (dashboard.blade rendered to HTML for
# eyeballing without spinning up a server).
/storage/dashboard-render.html

# NOTE: /public/build is intentionally NOT ignored. Hostinger has no node,
# so Vite output is committed and ships via git pull. See deploy.ps1.

# Pre-existing selene (Lua linter) configs from earlier work in this
# directory. Keep on disk for whoever wrote them; not relevant to the
# Laravel project.
/selene.toml
/wow.yml
